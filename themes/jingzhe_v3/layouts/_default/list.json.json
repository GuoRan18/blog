{{- $.Scratch.Delete "pages" -}}
{{- $.Scratch.Set "pages" slice -}}

{{- if eq .Kind "page" -}}
  {{- $.Scratch.Set "pages" (slice .) -}}
{{- else -}}
  {{- $pages := .Data.Pages -}}
  {{- $.Scratch.Set "pages" $pages -}}
{{- end -}}

{{- $pages := $.Scratch.Get "pages" -}}
[
  {{- range $index, $page := $pages -}}
  {{- if $index }},{{end -}}
  {
    "uri": {{ $page.RelPermalink | jsonify }},
    "title": {{ $page.Title | jsonify }},
    "content": {{ $page.Plain | jsonify }}
  }
  {{- end -}}
]
